{
  "expo": {
    "name": "Inner Light",
    "slug": "inner-light",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "innerlight",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.innerlight.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF5FF"
      },
      "package": "com.innerlight.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Inner Light to use the microphone for voice journaling and affirmations.",
          "speechRecognitionPermission": "Allow Inner Light to use speech recognition to transcribe your voice.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Inner Light to access your photos so you can attach them to journal entries."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Inner Light to tag journal entries with where you wrote them."
        }
      ]
    ]
  }
}
