{
  "expo": {
    "name": "Inner Light",
    "slug": "inner-light",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "innerlight",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.innerlight.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF5FF"
      },
      "package": "com.innerlight.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-font"]
  }
}
